rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si el usuario es ADMIN o COLABORADOR
    function isStaff() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.rol in ['administrador', 'colaborador'];
    }

    // Función para verificar si el usuario es el dueño del documento
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- COLECCIÓN: users ---
    match /users/{userId} {
      allow read: if isAuthenticated(); // Cualquiera logueado puede leer perfiles (necesario para validar roles)
      allow create: if isOwner(userId); // Solo el usuario puede crear su propio perfil al registrarse
      allow update: if isOwner(userId) || isStaff(); // El usuario puede editar sus datos o el staff también
      allow delete: if isStaff(); // Solo staff puede borrar usuarios
    }

    // --- COLECCIÓN: quotes (Cotizaciones) ---
    match /quotes/{quoteId} {
      allow read: if isAuthenticated() && (
        isStaff() || 
        (resource.data.cliente != null && resource.data.cliente.uid == request.auth.uid)
      );
      // Permitir creación de cotizaciones directa por cualquier usuario
      allow create: if true; 
      // Solo el personal (staff) de la aplicación puede modificar o eliminar cotizaciones
      allow update, delete: if isAuthenticated() && isStaff();
    }

    // --- COLECCIÓN: products ---
    match /products/{productId} {
      allow read: if true; // Público
      allow create, update, delete: if isStaff(); // Solo staff
    }

    // --- COLECCIÓN: reports ---
    match /reports/{reportId} {
      allow read: if isAuthenticated() && isStaff();
      allow create, update, delete: if isAuthenticated() && isStaff();
    }

    // --- COLECCIÓN: settings ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isStaff();
    }
  }
}