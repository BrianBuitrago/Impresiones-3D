# Ejemplo de archivo .env para desplegar el backend

# Entorno
ENVIRONMENT=production
PORT=8000
HOST=0.0.0.0

# Firebase (opcional)
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# Cuentas admin
ADMIN_1_EMAIL=admin1@example.com
ADMIN_1_PASSWORD=changeme
ADMIN_2_EMAIL=admin2@example.com
ADMIN_2_PASSWORD=changeme
ALLOWED_ADMIN_EMAILS=

# Cloudinary (rellena con las credenciales reales en tu .env local o en Vercel)
CLOUD_NAME=dobul5gbb
API_KEY=TU_API_KEY
API_SECRET=TU_API_SECRET
CLOUDINARY_UPLOAD_PRESET=impresiones3d_unsigned
